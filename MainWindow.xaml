<Window x:Class="VucemDownloader.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="VUCEM Suite - Descarga Masiva de Expedientes" 
        Height="750" Width="1100" 
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="#f8fafc">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#ffffff" Padding="25,0" BorderBrush="#e2e8f0" BorderThickness="0,0,0,1">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="#0f172a" CornerRadius="8" Width="48" Height="48" Margin="0,0,15,0">
                        <Viewbox Width="24" Height="24" Margin="10">
                            <Path Fill="#ffffff" Data="M14,2H6A2,2 0 0,0 4,4V20A2,2 0 0,0 6,22H18A2,2 0 0,0 20,20V8L14,2M18,20H6V4H13V9H18V20Z"/>
                        </Viewbox>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="VUCEM Suite" 
                                   FontSize="22" FontWeight="600" 
                                   Foreground="#0f172a"/>
                        <TextBlock Text="Descarga Masiva de Expedientes" 
                                   FontSize="11" 
                                   Foreground="#64748b"/>
                    </StackPanel>
                </StackPanel>
                
                <StackPanel Orientation="Horizontal" 
                            HorizontalAlignment="Right" 
                            VerticalAlignment="Center">
                    <Border Background="#f1f5f9" CornerRadius="20" Padding="14,8" Margin="0,0,12,0">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse x:Name="ellipseStatus" Width="8" Height="8" Fill="#dc2626" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock x:Name="lblSesion" 
                                       Text="Sin sesión activa" 
                                       FontSize="12" 
                                       Foreground="#475569" 
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Button Content="Configuración" 
                            Height="36"
                            FontSize="12" FontWeight="500"
                            Background="#f1f5f9" 
                            Foreground="#475569"
                            Click="btnConfiguracion_Click"
                            Cursor="Hand"
                            Padding="16,0">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <TabControl Grid.Row="1" 
                    Margin="24" 
                    Background="Transparent"
                    BorderThickness="0"
                    SelectionChanged="TabControl_SelectionChanged">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Border x:Name="Border" 
                                        Background="#f1f5f9" 
                                        CornerRadius="8,8,0,0" 
                                        Padding="20,12"
                                        Margin="0,0,2,0">
                                    <ContentPresenter x:Name="ContentSite"
                                                      ContentSource="Header"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Border" Property="Background" Value="#ffffff"/>
                                        <Setter TargetName="Border" Property="BorderBrush" Value="#0369a1"/>
                                        <Setter TargetName="Border" Property="BorderThickness" Value="0,0,0,3"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Border" Property="Background" Value="#e2e8f0"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                    <Setter Property="Foreground" Value="#475569"/>
                    <Setter Property="FontSize" Value="13"/>
                    <Setter Property="FontWeight" Value="500"/>
                    <Setter Property="Margin" Value="0,0,0,-1"/>
                </Style>
            </TabControl.Resources>

            <TabItem Header="COVEs">
                <Border Background="#ffffff" CornerRadius="0,12,12,12" Padding="28">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.08" Direction="270"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Descarga Masiva de COVEs" 
                                   FontSize="18" FontWeight="600" 
                                   Foreground="#0f172a" 
                                   Margin="0,0,0,20"/>

                        <Border Grid.Row="1" Background="#f8fafc" CornerRadius="8" Padding="20" Margin="0,0,0,20">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                    <TextBlock Text="Fecha Inicio" FontSize="11" Foreground="#64748b" Margin="0,0,0,6"/>
                                    <DatePicker x:Name="dtpCoveFechaInicio" 
                                               Background="#ffffff" 
                                               BorderBrush="#e2e8f0"
                                               Padding="8,6"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Margin="0,0,12,0">
                                    <TextBlock Text="Fecha Fin" FontSize="11" Foreground="#64748b" Margin="0,0,0,6"/>
                                    <DatePicker x:Name="dtpCoveFechaFin" 
                                               Background="#ffffff" 
                                               BorderBrush="#e2e8f0"
                                               Padding="8,6"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2" Margin="0,0,12,0">
                                    <TextBlock Text="Folio / eDocument" FontSize="11" FontWeight="SemiBold" Foreground="#0369a1" Margin="0,0,0,6"/>
                                    <TextBox x:Name="txtCoveFolio" 
                                             Background="#f0f9ff" 
                                             BorderBrush="#bae6fd"
                                             Padding="10,8"
                                             VerticalContentAlignment="Center"
                                             ToolTip="Ingrese el eDocument para búsqueda directa"/>
                                </StackPanel>

                                <StackPanel Grid.Column="3" Margin="0,0,12,0">
                                    <TextBlock Text="RFC Emisor" FontSize="11" Foreground="#64748b" Margin="0,0,0,6"/>
                                    <TextBox x:Name="txtCoveRfcEmisor" 
                                             Background="#ffffff" 
                                             BorderBrush="#e2e8f0"
                                             Padding="10,8"
                                             VerticalContentAlignment="Center"/>
                                </StackPanel>

                                <StackPanel Grid.Column="4" Margin="0,0,12,0">
                                    <TextBlock Text="Estado" FontSize="11" Foreground="#64748b" Margin="0,0,0,6"/>
                                    <ComboBox x:Name="cmbCoveEstado" 
                                             Background="#ffffff" 
                                             BorderBrush="#e2e8f0"
                                             Padding="10,8">
                                        <ComboBoxItem Content="Todos" IsSelected="True"/>
                                        <ComboBoxItem Content="Completado"/>
                                        <ComboBoxItem Content="Pendiente"/>
                                        <ComboBoxItem Content="Procesando"/>
                                        <ComboBoxItem Content="Rechazado"/>
                                    </ComboBox>
                                </StackPanel>

                                <Button Grid.Column="5" 
                                        Content="Buscar" 
                                        Height="36"
                                        FontSize="13" FontWeight="600"
                                        Background="#0369a1" 
                                        Foreground="White"
                                        Click="btnBuscarCoves_Click"
                                        Cursor="Hand"
                                        Padding="24,0"
                                        VerticalAlignment="Bottom">
                                    <Button.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="6"/>
                                        </Style>
                                    </Button.Resources>
                                </Button>
                            </Grid>
                        </Border>

                        <DataGrid Grid.Row="2" 
                                  x:Name="dgCoves" 
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  SelectionMode="Extended"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  Background="#ffffff"
                                  BorderBrush="#e2e8f0"
                                  BorderThickness="1"
                                  GridLinesVisibility="Horizontal"
                                  HorizontalGridLinesBrush="#f1f5f9"
                                  RowBackground="#ffffff"
                                  AlternatingRowBackground="#fafafa">
                            <DataGrid.Columns>
                                <DataGridCheckBoxColumn Binding="{Binding Seleccionado}" Width="40"/>
                                <DataGridTextColumn Header="No. Operación" Binding="{Binding NumeroOperacion}" Width="150"/>
                                <DataGridTextColumn Header="Fecha" Binding="{Binding FechaCreacion, StringFormat=dd/MM/yyyy}" Width="100"/>
                                <DataGridTextColumn Header="RFC Emisor" Binding="{Binding RfcEmisor}" Width="130"/>
                                <DataGridTextColumn Header="RFC Receptor" Binding="{Binding RfcReceptor}" Width="130"/>
                                <DataGridTextColumn Header="Tipo" Binding="{Binding TipoOperacion}" Width="100"/>
                                <DataGridTextColumn Header="Estado" Binding="{Binding Estado}" Width="100"/>
                                <DataGridTextColumn Header="Valor" Binding="{Binding ValorTotal, StringFormat=C2}" Width="120"/>
                                <DataGridTextColumn Header="Moneda" Binding="{Binding Moneda}" Width="70"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,16,0,0">
                            <Button Content="Descargar PDF" 
                                    Height="40"
                                    FontSize="13" FontWeight="500"
                                    Background="#059669" 
                                    Foreground="White"
                                    Click="btnDescargarCovePdf_Click"
                                    Cursor="Hand"
                                    Padding="20,0"
                                    Margin="0,0,12,0">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="6"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                            <Button Content="Descargar XML" 
                                    Height="40"
                                    FontSize="13" FontWeight="500"
                                    Background="#7c3aed" 
                                    Foreground="White"
                                    Click="btnDescargarCoveXml_Click"
                                    Cursor="Hand"
                                    Padding="20,0"
                                    Margin="0,0,12,0">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="6"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                            <Button Content="Ver Detalle" 
                                    Height="40"
                                    FontSize="13" FontWeight="500"
                                    Background="#f1f5f9" 
                                    Foreground="#475569"
                                    BorderBrush="#e2e8f0"
                                    Click="btnVerDetalleCove_Click"
                                    Cursor="Hand"
                                    Padding="20,0">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="6"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>
            </TabItem>

            <TabItem Header="Manifestaciones (E2)">
                <Border Background="#ffffff" CornerRadius="0,12,12,12" Padding="28">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.08" Direction="270"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Descarga Masiva de Manifestaciones de Valor" 
                                   FontSize="18" FontWeight="600" 
                                   Foreground="#0f172a" 
                                   Margin="0,0,0,20"/>

                        <Border Grid.Row="1" Background="#f8fafc" CornerRadius="8" Padding="20" Margin="0,0,0,20">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                    <TextBlock Text="Fecha Inicio" FontSize="11" Foreground="#64748b" Margin="0,0,0,6"/>
                                    <DatePicker x:Name="dtpManifFechaInicio" 
                                               Background="#ffffff" 
                                               BorderBrush="#e2e8f0"
                                               Padding="8,6"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Margin="0,0,12,0">
                                    <TextBlock Text="Fecha Fin" FontSize="11" Foreground="#64748b" Margin="0,0,0,6"/>
                                    <DatePicker x:Name="dtpManifFechaFin" 
                                               Background="#ffffff" 
                                               BorderBrush="#e2e8f0"
                                               Padding="8,6"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2" Margin="0,0,12,0">
                                    <TextBlock Text="Folio / Operación" FontSize="11" FontWeight="SemiBold" Foreground="#0369a1" Margin="0,0,0,6"/>
                                    <TextBox x:Name="txtManifFolio" 
                                             Background="#f0f9ff" 
                                             BorderBrush="#bae6fd"
                                             Padding="10,8"
                                             VerticalContentAlignment="Center"
                                             ToolTip="Ingrese el eDocument o Número de Operación"/>
                                </StackPanel>

                                <StackPanel Grid.Column="3" Margin="0,0,12,0">
                                    <TextBlock Text="RFC Solicitante" FontSize="11" Foreground="#64748b" Margin="0,0,0,6"/>
                                    <TextBox x:Name="txtManifRfc" 
                                             Background="#ffffff" 
                                             BorderBrush="#e2e8f0"
                                             Padding="10,8"
                                             VerticalContentAlignment="Center"/>
                                </StackPanel>

                                <StackPanel Grid.Column="4" Margin="0,0,12,0">
                                    <TextBlock Text="Estado" FontSize="11" Foreground="#64748b" Margin="0,0,0,6"/>
                                    <ComboBox x:Name="cmbManifEstado" 
                                             Background="#ffffff" 
                                             BorderBrush="#e2e8f0"
                                             Padding="10,8">
                                        <ComboBoxItem Content="Todos" IsSelected="True"/>
                                        <ComboBoxItem Content="Completado"/>
                                        <ComboBoxItem Content="Pendiente"/>
                                        <ComboBoxItem Content="Procesando"/>
                                    </ComboBox>
                                </StackPanel>

                                <Button Grid.Column="5" 
                                        Content="Buscar" 
                                        Height="36"
                                        FontSize="13" FontWeight="600"
                                        Background="#0369a1" 
                                        Foreground="White"
                                        Click="btnBuscarManifestaciones_Click"
                                        Cursor="Hand"
                                        Padding="24,0"
                                        VerticalAlignment="Bottom">
                                    <Button.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="6"/>
                                        </Style>
                                    </Button.Resources>
                                </Button>
                            </Grid>
                        </Border>

                        <DataGrid Grid.Row="2" 
                                  x:Name="dgManifestaciones" 
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  SelectionMode="Extended"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  Background="#ffffff"
                                  BorderBrush="#e2e8f0"
                                  BorderThickness="1"
                                  GridLinesVisibility="Horizontal"
                                  HorizontalGridLinesBrush="#f1f5f9"
                                  RowBackground="#ffffff"
                                  AlternatingRowBackground="#fafafa">
                            <DataGrid.Columns>
                                <DataGridCheckBoxColumn Binding="{Binding Seleccionado}" Width="40"/>
                                <DataGridTextColumn Header="No. Operación" Binding="{Binding NumeroOperacion}" Width="150"/>
                                <DataGridTextColumn Header="Fecha" Binding="{Binding FechaCreacion, StringFormat=dd/MM/yyyy}" Width="100"/>
                                <DataGridTextColumn Header="RFC Solicitante" Binding="{Binding RfcSolicitante}" Width="130"/>
                                <DataGridTextColumn Header="Tipo" Binding="{Binding TipoOperacion}" Width="80"/>
                                <DataGridTextColumn Header="No. Pedimento" Binding="{Binding NumeroPedimento}" Width="130"/>
                                <DataGridTextColumn Header="Estado" Binding="{Binding Estado}" Width="100"/>
                                <DataGridTextColumn Header="Valor Total" Binding="{Binding ValorTotal, StringFormat=C2}" Width="120"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,16,0,0">
                            <Button Content="Descargar PDF" 
                                    Height="40"
                                    FontSize="13" FontWeight="500"
                                    Background="#059669" 
                                    Foreground="White"
                                    Click="btnDescargarManifPdf_Click"
                                    Cursor="Hand"
                                    Padding="20,0"
                                    Margin="0,0,12,0">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="6"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                            <Button Content="Descargar XML" 
                                    Height="40"
                                    FontSize="13" FontWeight="500"
                                    Background="#7c3aed" 
                                    Foreground="White"
                                    Click="btnDescargarManifXml_Click"
                                    Cursor="Hand"
                                    Padding="20,0"
                                    Margin="0,0,12,0">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="6"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                            <Button Content="Ver Detalle" 
                                    Height="40"
                                    FontSize="13" FontWeight="500"
                                    Background="#f1f5f9" 
                                    Foreground="#475569"
                                    BorderBrush="#e2e8f0"
                                    Click="btnVerDetalleManif_Click"
                                    Cursor="Hand"
                                    Padding="20,0">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="6"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>
            </TabItem>

            <TabItem Header="Pedimentos">
                <Border Background="#ffffff" CornerRadius="0,12,12,12" Padding="28">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.08" Direction="270"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Consulta de Pedimentos" 
                                   FontSize="18" FontWeight="600" 
                                   Foreground="#0f172a" 
                                   Margin="0,0,0,20"/>

                        <Border Grid.Row="1" Background="#f8fafc" CornerRadius="8" Padding="20" Margin="0,0,0,20">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                    <TextBlock Text="Fecha Inicio" FontSize="11" Foreground="#64748b" Margin="0,0,0,6"/>
                                    <DatePicker x:Name="dtpPedFechaInicio" 
                                               Background="#ffffff" 
                                               BorderBrush="#e2e8f0"
                                               Padding="8,6"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Margin="0,0,12,0">
                                    <TextBlock Text="Fecha Fin" FontSize="11" Foreground="#64748b" Margin="0,0,0,6"/>
                                    <DatePicker x:Name="dtpPedFechaFin" 
                                               Background="#ffffff" 
                                               BorderBrush="#e2e8f0"
                                               Padding="8,6"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2" Margin="0,0,12,0">
                                    <TextBlock Text="RFC Importador" FontSize="11" Foreground="#64748b" Margin="0,0,0,6"/>
                                    <TextBox x:Name="txtPedRfc" 
                                             Background="#ffffff" 
                                             BorderBrush="#e2e8f0"
                                             Padding="10,8"
                                             VerticalContentAlignment="Center"/>
                                </StackPanel>

                                <StackPanel Grid.Column="3" Margin="0,0,12,0">
                                    <TextBlock Text="Aduana" FontSize="11" Foreground="#64748b" Margin="0,0,0,6"/>
                                    <ComboBox x:Name="cmbPedAduana" 
                                             Background="#ffffff" 
                                             BorderBrush="#e2e8f0"
                                             Padding="10,8">
                                        <ComboBoxItem Content="Todas" IsSelected="True"/>
                                        <ComboBoxItem Content="Manzanillo"/>
                                        <ComboBoxItem Content="Veracruz"/>
                                        <ComboBoxItem Content="Guadalajara"/>
                                        <ComboBoxItem Content="Mexico"/>
                                        <ComboBoxItem Content="Tijuana"/>
                                    </ComboBox>
                                </StackPanel>

                                <Button Grid.Column="4" 
                                        Content="Buscar" 
                                        Height="36"
                                        FontSize="13" FontWeight="500"
                                        Background="#0369a1" 
                                        Foreground="White"
                                        Click="btnBuscarPedimentos_Click"
                                        Cursor="Hand"
                                        Padding="24,0"
                                        VerticalAlignment="Bottom">
                                    <Button.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="6"/>
                                        </Style>
                                    </Button.Resources>
                                </Button>
                            </Grid>
                        </Border>

                        <DataGrid Grid.Row="2" 
                                  x:Name="dgPedimentos" 
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  SelectionMode="Extended"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  Background="#ffffff"
                                  BorderBrush="#e2e8f0"
                                  BorderThickness="1"
                                  GridLinesVisibility="Horizontal"
                                  HorizontalGridLinesBrush="#f1f5f9"
                                  RowBackground="#ffffff"
                                  AlternatingRowBackground="#fafafa">
                            <DataGrid.Columns>
                                <DataGridCheckBoxColumn Binding="{Binding Seleccionado}" Width="40"/>
                                <DataGridTextColumn Header="No. Pedimento" Binding="{Binding NumeroPedimento}" Width="140"/>
                                <DataGridTextColumn Header="Fecha Pago" Binding="{Binding FechaPago, StringFormat=dd/MM/yyyy}" Width="100"/>
                                <DataGridTextColumn Header="RFC Importador" Binding="{Binding RfcImportador}" Width="130"/>
                                <DataGridTextColumn Header="Aduana" Binding="{Binding Aduana}" Width="120"/>
                                <DataGridTextColumn Header="Tipo" Binding="{Binding TipoOperacion}" Width="100"/>
                                <DataGridTextColumn Header="Estado" Binding="{Binding Estado}" Width="100"/>
                                <DataGridTextColumn Header="Valor Aduana" Binding="{Binding ValorAduana, StringFormat=C2}" Width="120"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,16,0,0">
                            <Button Content="Descargar PDF" 
                                    Height="40"
                                    FontSize="13" FontWeight="500"
                                    Background="#059669" 
                                    Foreground="White"
                                    Click="btnDescargarPedimentoPdf_Click"
                                    Cursor="Hand"
                                    Padding="20,0"
                                    Margin="0,0,12,0">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="6"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                            <Button Content="Ver Detalle" 
                                    Height="40"
                                    FontSize="13" FontWeight="500"
                                    Background="#f1f5f9" 
                                    Foreground="#475569"
                                    BorderBrush="#e2e8f0"
                                    Click="btnVerDetallePedimento_Click"
                                    Cursor="Hand"
                                    Padding="20,0">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="6"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>
            </TabItem>

            <TabItem Header="Reportes">
                <Border Background="#ffffff" CornerRadius="0,12,12,12" Padding="28">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.08" Direction="270"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="Reportes y Estadisticas" 
                                   FontSize="18" FontWeight="600" 
                                   Foreground="#0f172a" 
                                   Margin="0,0,0,24"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Background="#f0f9ff" CornerRadius="12" Padding="24" Margin="0,0,12,0">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="Total COVEs" FontSize="14" Foreground="#475569" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="lblTotalCoves" Text="0" FontSize="36" FontWeight="700" Foreground="#0369a1" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1" Background="#f0fdf4" CornerRadius="12" Padding="24" Margin="0,0,12,0">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="Total Manifestaciones" FontSize="14" Foreground="#475569" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="lblTotalManifestaciones" Text="0" FontSize="36" FontWeight="700" Foreground="#059669" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2" Background="#fef2f2" CornerRadius="12" Padding="24">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="Total Pedimentos" FontSize="14" Foreground="#475569" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="lblTotalPedimentos" Text="0" FontSize="36" FontWeight="700" Foreground="#dc2626" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Border Background="#f8fafc" CornerRadius="8" Padding="24" Margin="0,24,0,0">
                            <StackPanel>
                                <TextBlock Text="Informacion de la Sesion" FontSize="16" FontWeight="600" Foreground="#0f172a" Margin="0,0,0,16"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="RFC:" FontWeight="500" Foreground="#475569"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" x:Name="lblReporteRfc" Text="No disponible"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Certificado:" FontWeight="500" Foreground="#475569" Margin="0,8,0,0"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" x:Name="lblReporteCert" Text="No disponible" Margin="0,8,0,0"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Licencia:" FontWeight="500" Foreground="#475569" Margin="0,8,0,0"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" x:Name="lblReporteLicencia" Text="No disponible" Margin="0,8,0,0"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </TabItem>
        </TabControl>

        <Border x:Name="progressOverlay" Grid.RowSpan="2" Background="#80000000" Visibility="Collapsed">
            <Border Background="#ffffff" CornerRadius="12" Padding="40" HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel>
                    <ProgressBar x:Name="progressBar" IsIndeterminate="True" Width="300" Height="6"/>
                    <TextBlock x:Name="lblProgreso" Text="Procesando..." FontSize="14" Foreground="#475569" HorizontalAlignment="Center" Margin="0,16,0,0"/>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</Window>
