<Window x:Class="VucemDownloader.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="VUCEM Suite - Descarga Masiva" 
        Height="650" Width="1000" 
        WindowStartupLocation="CenterScreen"
        Background="#f8fafc">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#ffffff" Padding="25,0" BorderBrush="#e2e8f0" BorderThickness="0,0,0,1">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="#0f172a" CornerRadius="8" Width="48" Height="48" Margin="0,0,15,0">
                        <Viewbox Width="24" Height="24" Margin="10">
                            <Path Fill="#ffffff" Data="M14,2H6A2,2 0 0,0 4,4V20A2,2 0 0,0 6,22H18A2,2 0 0,0 20,20V8L14,2M18,20H6V4H13V9H18V20Z"/>
                        </Viewbox>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="VUCEM Suite" 
                                   FontSize="22" FontWeight="600" 
                                   Foreground="#0f172a"/>
                        <TextBlock Text="Descarga Masiva de Comprobantes" 
                                   FontSize="11" 
                                   Foreground="#64748b"/>
                    </StackPanel>
                </StackPanel>
                
                <StackPanel Orientation="Horizontal" 
                            HorizontalAlignment="Right" 
                            VerticalAlignment="Center">
                    <Border Background="#f1f5f9" CornerRadius="20" Padding="14,8">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="8" Height="8" Fill="#0369a1" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock x:Name="lblSesion" 
                                       Text="Sin sesión VUCEM" 
                                       FontSize="12" 
                                       Foreground="#475569" 
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <TabControl Grid.Row="1" 
                    Margin="24" 
                    Background="Transparent"
                    BorderThickness="0">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Border x:Name="Border" 
                                        Background="#f1f5f9" 
                                        CornerRadius="8,8,0,0" 
                                        Padding="20,12"
                                        Margin="0,0,2,0">
                                    <ContentPresenter x:Name="ContentSite"
                                                      ContentSource="Header"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Border" Property="Background" Value="#ffffff"/>
                                        <Setter TargetName="Border" Property="BorderBrush" Value="#0369a1"/>
                                        <Setter TargetName="Border" Property="BorderThickness" Value="0,0,0,0"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Border" Property="Background" Value="#e2e8f0"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                    <Setter Property="Foreground" Value="#475569"/>
                    <Setter Property="FontSize" Value="13"/>
                    <Setter Property="FontWeight" Value="500"/>
                    <Setter Property="Margin" Value="0,0,0,-1"/>
                </Style>
            </TabControl.Resources>

            <TabItem Header="Descargar CFDIs">
                <Border Background="#ffffff" CornerRadius="0,12,12,12" Padding="28">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.08" Direction="270"/>
                    </Border.Effect>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="Descarga Masiva de Comprobantes Fiscales" 
                                       FontSize="18" FontWeight="600" 
                                       Foreground="#0f172a" 
                                       Margin="0,0,0,24"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="130"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="48"/>
                                    <RowDefinition Height="48"/>
                                    <RowDefinition Height="48"/>
                                    <RowDefinition Height="48"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Fecha Inicio:" 
                                           Foreground="#64748b" VerticalAlignment="Center"/>
                                <DatePicker Grid.Row="0" Grid.Column="1" 
                                           x:Name="dtpFechaInicio" 
                                           Background="#f8fafc" 
                                           BorderBrush="#e2e8f0"
                                           Padding="10,8"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Fecha Fin:" 
                                           Foreground="#64748b" VerticalAlignment="Center"/>
                                <DatePicker Grid.Row="1" Grid.Column="1" 
                                           x:Name="dtpFechaFin" 
                                           Background="#f8fafc" 
                                           BorderBrush="#e2e8f0"
                                           Padding="10,8"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="RFC Emisor:" 
                                           Foreground="#64748b" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="2" Grid.Column="1" 
                                        x:Name="txtRfcEmisor" 
                                        Background="#f8fafc" 
                                        BorderBrush="#e2e8f0"
                                        Padding="10,8"
                                        VerticalContentAlignment="Center"/>

                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Estado:" 
                                           Foreground="#64748b" VerticalAlignment="Center"/>
                                <ComboBox Grid.Row="3" Grid.Column="1" 
                                         x:Name="cmbEstado" 
                                         Background="#f8fafc" 
                                         BorderBrush="#e2e8f0"
                                         Padding="10,8">
                                    <ComboBoxItem Content="Todos" IsSelected="True"/>
                                    <ComboBoxItem Content="Vigente"/>
                                    <ComboBoxItem Content="Cancelado"/>
                                </ComboBox>
                            </Grid>

                            <Button x:Name="btnDescargar" 
                                    Content="Iniciar Descarga" 
                                    Height="44" 
                                    FontSize="14" FontWeight="500"
                                    Background="#0369a1" 
                                    Foreground="White"
                                    Margin="0,28,0,12"
                                    Click="btnDescargar_Click"
                                    Cursor="Hand"
                                    HorizontalAlignment="Left"
                                    Padding="24,0">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="6"/>
                                    </Style>
                                </Button.Resources>
                            </Button>

                            <ProgressBar x:Name="progressDescargas" 
                                        Height="6" 
                                        Margin="0,8,0,8"
                                        Visibility="Collapsed"
                                        Background="#e2e8f0"
                                        Foreground="#0369a1"/>

                            <TextBlock x:Name="lblProgreso" 
                                       Text="" 
                                       FontSize="12" 
                                       Foreground="#64748b"/>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </TabItem>

            <TabItem Header="Consultar">
                <Border Background="#ffffff" CornerRadius="0,12,12,12" Padding="28">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.08" Direction="270"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="Consulta de Comprobantes" 
                                   FontSize="18" FontWeight="600" 
                                   Foreground="#0f172a" 
                                   Margin="0,0,0,24"/>

                        <TextBlock Text="Buscar por UUID:" Foreground="#64748b" Margin="0,0,0,8"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="110"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" 
                                    x:Name="txtUuid" 
                                    Background="#f8fafc" 
                                    BorderBrush="#e2e8f0"
                                    Padding="12,10"
                                    Margin="0,0,12,0"/>
                            <Button Grid.Column="1" 
                                   Content="Buscar" 
                                   Background="#0369a1" 
                                   Foreground="White"
                                   Click="btnBuscar_Click">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="6"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                        </Grid>

                        <DataGrid x:Name="dgResultados" 
                                  Margin="0,24,0,0" 
                                  AutoGenerateColumns="True"
                                  IsReadOnly="True"
                                  Height="340"
                                  Background="#ffffff"
                                  BorderBrush="#e2e8f0"
                                  BorderThickness="1"
                                  GridLinesVisibility="Horizontal"
                                  HorizontalGridLinesBrush="#e2e8f0"/>
                    </StackPanel>
                </Border>
            </TabItem>

            <TabItem Header="Cancelar">
                <Border Background="#ffffff" CornerRadius="0,12,12,12" Padding="28">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.08" Direction="270"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="Cancelación de CFDI" 
                                   FontSize="18" FontWeight="600" 
                                   Foreground="#0f172a" 
                                   Margin="0,0,0,24"/>

                        <TextBlock Text="UUID del CFDI a cancelar:" Foreground="#64748b" Margin="0,0,0,8"/>
                        <TextBox x:Name="txtUuidCancelar" 
                                Background="#f8fafc" 
                                BorderBrush="#e2e8f0"
                                Padding="12,10"
                                Margin="0,0,0,16"/>

                        <TextBlock Text="Motivo de cancelación:" Foreground="#64748b" Margin="0,0,0,8"/>
                        <ComboBox x:Name="cmbMotivo" 
                                 Background="#f8fafc" 
                                 BorderBrush="#e2e8f0"
                                 Padding="12,10"
                                 Margin="0,0,0,20">
                            <ComboBoxItem Content="01 - Comprobante modificado"/>
                            <ComboBoxItem Content="02 - Comprobante emitido incorrectamente"/>
                            <ComboBoxItem Content="03 - No se llevó a cabo la operación"/>
                            <ComboBoxItem Content="04 - Operación nominativa"/>
                        </ComboBox>

                        <Button x:Name="btnCancelar" 
                                Content="Solicitar Cancelación" 
                                Height="44" 
                                FontSize="14" FontWeight="500"
                                Background="#dc2626" 
                                Foreground="White"
                                Click="btnCancelar_Click"
                                Cursor="Hand"
                                HorizontalAlignment="Left"
                                Padding="24,0">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="6"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </StackPanel>
                </Border>
            </TabItem>

            <TabItem Header="Validar XML">
                <Border Background="#ffffff" CornerRadius="0,12,12,12" Padding="28">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.08" Direction="270"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="Validación de CFDI" 
                                   FontSize="18" FontWeight="600" 
                                   Foreground="#0f172a" 
                                   Margin="0,0,0,24"/>

                        <Button x:Name="btnSeleccionarXml" 
                                Content="Seleccionar archivo XML" 
                                Height="44" 
                                Background="#f1f5f9" 
                                BorderBrush="#e2e8f0"
                                Foreground="#475569"
                                Click="btnSeleccionarXml_Click"
                                HorizontalAlignment="Left"
                                Padding="20,0"
                                Cursor="Hand">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="6"/>
                                </Style>
                            </Button.Resources>
                        </Button>

                        <TextBlock x:Name="lblArchivoXml" 
                                   Text="Ningún archivo seleccionado" 
                                   FontSize="12" 
                                   Foreground="#64748b"
                                   Margin="0,12,0,16"/>

                        <Button x:Name="btnValidarXml" 
                                Content="Validar CFDI" 
                                Height="44" 
                                FontSize="14" FontWeight="500"
                                Background="#059669" 
                                Foreground="White"
                                Click="btnValidarXml_Click"
                                HorizontalAlignment="Left"
                                Padding="24,0"
                                Cursor="Hand">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="6"/>
                                </Style>
                            </Button.Resources>
                        </Button>

                        <TextBlock x:Name="lblResultadoValidacion" 
                                   Text="" 
                                   FontSize="13" 
                                   Foreground="#475569"
                                   Margin="0,20,0,0"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </TabItem>

            <TabItem Header="Configuración">
                <Border Background="#ffffff" CornerRadius="0,12,12,12" Padding="28">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.08" Direction="270"/>
                    </Border.Effect>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="Información de la Aplicación" 
                                       FontSize="18" FontWeight="600" 
                                       Foreground="#0f172a" 
                                       Margin="0,0,0,20"/>

                            <Border Background="#f8fafc" 
                                    CornerRadius="8" 
                                    Padding="20" 
                                    Margin="0,0,0,24"
                                    BorderBrush="#e2e8f0"
                                    BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Background="#e0f2fe" CornerRadius="8" Width="44" Height="44" Margin="0,0,16,0">
                                        <Viewbox Width="22" Height="22" Margin="10">
                                            <Path Fill="#0369a1" Data="M12,2A10,10 0 0,1 22,12A10,10 0 0,1 12,22A10,10 0 0,1 2,12A10,10 0 0,1 12,2M12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20A8,8 0 0,0 20,12A8,8 0 0,0 12,4M11,16.5L6.5,12L7.91,10.59L11,13.67L16.59,8.09L18,9.5L11,16.5Z"/>
                                        </Viewbox>
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="Licencia" 
                                                   FontSize="14" FontWeight="600" 
                                                   Foreground="#0f172a" 
                                                   Margin="0,0,0,4"/>
                                        <TextBlock x:Name="lblLicencia" 
                                                   Text="Clave: No activada" 
                                                   FontSize="13" 
                                                   Foreground="#475569"/>
                                        <TextBlock x:Name="lblVencimientoLicencia" 
                                                   Text="Vencimiento: -" 
                                                   FontSize="12" 
                                                   Foreground="#64748b"
                                                   Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <TextBlock Text="Configuración de Sesión VUCEM" 
                                       FontSize="18" FontWeight="600" 
                                       Foreground="#0f172a" 
                                       Margin="0,8,0,20"/>

                            <Border Background="#f8fafc" 
                                    CornerRadius="8" 
                                    Padding="20" 
                                    Margin="0,0,0,24"
                                    BorderBrush="#e2e8f0"
                                    BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="Credenciales FIEL"
                                               FontSize="14" FontWeight="600" 
                                               Foreground="#0f172a" 
                                               Margin="0,0,0,4"/>
                                    <TextBlock Text="Archivo .cer y .key para operaciones con el SAT"
                                               FontSize="12" 
                                               Foreground="#64748b"
                                               Margin="0,0,0,16"/>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,8,12">
                                            <TextBlock Text="Certificado (.cer)" FontSize="11" Foreground="#64748b" Margin="0,0,0,4"/>
                                            <TextBlock x:Name="lblInfoCert" Text="No cargado" FontSize="13" Foreground="#475569"/>
                                        </StackPanel>

                                        <StackPanel Grid.Row="0" Grid.Column="1" Margin="8,0,0,12">
                                            <TextBlock Text="Vigencia" FontSize="11" Foreground="#64748b" Margin="0,0,0,4"/>
                                            <TextBlock x:Name="lblVigencia" Text="-" FontSize="13" Foreground="#475569"/>
                                        </StackPanel>
                                    </Grid>

                                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                        <Button x:Name="btnIniciarSesion" 
                                                Content="Seleccionar Certificados" 
                                                Height="36" 
                                                FontSize="12" FontWeight="500"
                                                Background="#0369a1" 
                                                Foreground="White"
                                                Click="btnIniciarSesion_Click"
                                                Cursor="Hand"
                                                Padding="16,0">
                                            <Button.Resources>
                                                <Style TargetType="Border">
                                                    <Setter Property="CornerRadius" Value="6"/>
                                                </Style>
                                            </Button.Resources>
                                        </Button>

                                        <Button x:Name="btnCerrarSesion" 
                                                Content="Limpiar" 
                                                Height="36" 
                                                FontSize="12" FontWeight="500"
                                                Background="#dc2626" 
                                                Foreground="White"
                                                Click="btnCerrarSesion_Click"
                                                Cursor="Hand"
                                                Visibility="Collapsed"
                                                Margin="10,0,0,0"
                                                Padding="16,0">
                                            <Button.Resources>
                                                <Style TargetType="Border">
                                                    <Setter Property="CornerRadius" Value="6"/>
                                                </Style>
                                            </Button.Resources>
                                        </Button>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </TabItem>
        </TabControl>
    </Grid>
</Window>