<Window x:Class="VucemDownloader.NewExpedienteWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Nuevo Expediente"
        Height="700" Width="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F8FAFC"
        ShowInTaskbar="False">
    
    <Grid>
        <Border Background="#FFFFFF" CornerRadius="16" Margin="20">
            <Border.Effect>
                <DropShadowEffect BlurRadius="30" ShadowDepth="8" Opacity="0.12" Direction="270"/>
            </Border.Effect>
            
            <StackPanel Margin="40">
                <StackPanel HorizontalAlignment="Center" Margin="0,10,0,32">
                    <Border Background="#1E40AF" CornerRadius="14" Width="64" Height="64" Margin="0,0,0,18">
                        <Viewbox Width="32" Height="32" Margin="16">
                            <Path Fill="#FFFFFF" Data="M19,13H13V19H11V13H5V11H11V5H13V11H19V13Z"/>
                        </Viewbox>
                    </Border>
                    <TextBlock Text="Nuevo Expediente"
                               FontSize="22" FontWeight="700" 
                               HorizontalAlignment="Center" 
                               Foreground="#0F172A"/>
                    <TextBlock Text="Completa los datos del nuevo proyecto"
                               FontSize="13" 
                               HorizontalAlignment="Center" 
                               Foreground="#64748B" 
                               Margin="0,6,0,0"/>
                </StackPanel>

                <TextBlock Text="Nombre del Expediente *" 
                           FontSize="13" FontWeight="600" 
                           Foreground="#475569" 
                           Margin="0,0,0,10"/>
                <TextBox x:Name="txtNombre"
                         Style="{StaticResource ModernTextBox}"
                         Height="44"
                         Margin="0,0,0,24"/>

                <TextBlock Text="RFC *" 
                           FontSize="13" FontWeight="600" 
                           Foreground="#475569" 
                           Margin="0,0,0,10"/>
                <TextBox x:Name="txtRfc"
                         Style="{StaticResource ModernTextBox}"
                         CharacterCasing="Upper"
                         MaxLength="13"
                         Height="44"
                         Margin="0,0,0,24"/>

                <TextBlock Text="Aduana (opcional)" 
                           FontSize="13" FontWeight="600" 
                           Foreground="#475569" 
                           Margin="0,0,0,10"/>
                <TextBox x:Name="txtAduana"
                         Style="{StaticResource ModernTextBox}"
                         CharacterCasing="Upper"
                         Height="44"
                         Margin="0,0,0,28"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <Button x:Name="btnCrear"
                            Content="✓ Crear Expediente"
                            Click="btnCrear_Click"
                            Style="{StaticResource PrimaryButton}"
                            Height="50"
                            FontSize="15"
                            Grid.Column="1"
                            Padding="28,0"
                            Margin="0,0,14,0"/>
                    <Button Content="Cancelar"
                            Click="btnCancelar_Click"
                            Style="{StaticResource SecondaryButton}"
                            Height="50"
                            FontSize="15"
                            Grid.Column="2"
                            Padding="28,0"/>
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</Window>