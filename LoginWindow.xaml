<Window x:Class="VucemDownloader.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="VUCEM Suite - Credenciales FIEL" 
        Height="680" Width="480" 
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F8FAFC">
    <Grid>
        <Border Background="#FFFFFF" CornerRadius="16" Margin="20">
            <Border.Effect>
                <DropShadowEffect BlurRadius="30" ShadowDepth="8" Opacity="0.1" Direction="270"/>
            </Border.Effect>
            
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="36">
                    <StackPanel HorizontalAlignment="Center" Margin="0,8,0,32">
                        <Border Background="#1E40AF" CornerRadius="14" Width="64" Height="64" Margin="0,0,0,20">
                            <Viewbox Width="32" Height="32" Margin="16">
                                <Path Fill="#FFFFFF" Data="M12,1L3,5V11C3,16.55 6.84,21.74 12,23C17.16,21.74 21,16.55 21,11V5L12,1M12,5A3,3 0 0,1 15,8A3,3 0 0,1 12,11A3,3 0 0,1 9,8A3,3 0 0,1 12,5M17.13,17C15.92,18.85 14.11,20.24 12,20.92C9.89,20.24 8.08,18.85 6.87,17C6.53,16.5 6.24,16 6,15.47C6,15.47 9,14 12,14C15,14 18,15.47 18,15.47C17.76,16 17.47,16.5 17.13,17Z"/>
                            </Viewbox>
                        </Border>
                        <TextBlock Text="Credenciales FIEL"
                                   FontSize="24" FontWeight="700" 
                                   HorizontalAlignment="Center" 
                                   Foreground="#0F172A"/>
                        <TextBlock Text="Ingresa tu certificado y llave privada"
                                   FontSize="13" 
                                   HorizontalAlignment="Center" 
                                   Foreground="#64748B" 
                                   Margin="0,6,0,0"/>
                    </StackPanel>

                    <TextBlock Text="Certificado (.cer)" 
                               FontSize="12" FontWeight="600" 
                               Foreground="#475569" 
                               Margin="0,0,0,8"/>
                    <Button x:Name="btnCer" 
                            Content="📄  Seleccionar archivo..." 
                            Click="btnCer_Click" 
                            Height="44"
                            Margin="0,0,0,6"
                            Style="{StaticResource SecondaryButton}"
                            HorizontalContentAlignment="Left"
                            Padding="14,0"/>
                    <TextBlock x:Name="lblCerPath" 
                               Text="Ningún archivo seleccionado" 
                               FontSize="11" 
                               Foreground="#94A3B8" 
                               Margin="0,0,0,20"
                               TextTrimming="CharacterEllipsis"/>

                    <TextBlock Text="Llave Privada (.key)" 
                               FontSize="12" FontWeight="600" 
                               Foreground="#475569" 
                               Margin="0,0,0,8"/>
                    <Button x:Name="btnKey" 
                            Content="🔑  Seleccionar archivo..." 
                            Click="btnKey_Click" 
                            Height="44"
                            Margin="0,0,0,6"
                            Style="{StaticResource SecondaryButton}"
                            HorizontalContentAlignment="Left"
                            Padding="14,0"/>
                    <TextBlock x:Name="lblKeyPath" 
                               Text="Ningún archivo seleccionado" 
                               FontSize="11" 
                               Foreground="#94A3B8" 
                               Margin="0,0,0,20"
                               TextTrimming="CharacterEllipsis"/>

                    <TextBlock Text="Contraseña de la Llave" 
                               FontSize="12" FontWeight="600" 
                               Foreground="#475569" 
                               Margin="0,0,0,8"/>
                    <PasswordBox x:Name="txtPassword" 
                               Height="44" 
                               VerticalContentAlignment="Center" 
                               Margin="0,0,0,20"
                               Style="{StaticResource ModernPasswordBox}"
                               KeyDown="txtPassword_KeyDown"/>

                    <Border Background="#EFF6FF" CornerRadius="10" Padding="16" Margin="0,0,0,20">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <TextBlock Text="🔐" FontSize="14" Margin="0,0,8,0"/>
                                <TextBlock Text="Clave de Webservice VUCEM" 
                                           FontSize="13" FontWeight="600" 
                                           Foreground="#1E40AF"/>
                            </StackPanel>
                            <TextBlock Text="Contraseña proporcionada por VUCEM para acceso a servicios web" 
                                       FontSize="11" 
                                       Foreground="#64748B" 
                                       Margin="0,0,0,12"
                                       TextWrapping="Wrap"/>
                            <PasswordBox x:Name="txtWebservicePassword" 
                                        Height="40" 
                                        VerticalContentAlignment="Center" 
                                        Style="{StaticResource ModernPasswordBox}"
                                        Padding="12,0"/>
                        </StackPanel>
                    </Border>
     
                    <CheckBox x:Name="chkRecordar" 
                              Content="Recordar credenciales" 
                              Margin="0,0,0,24"
                              Style="{StaticResource ModernCheckBox}"/>

                    <Button x:Name="btnValidar" 
                            Content="✓ Validar Credenciales" 
                            Click="btnValidar_Click" 
                            Height="48" 
                            FontSize="14" FontWeight="600"
                            Style="{StaticResource PrimaryButton}"/>

                    <ProgressBar x:Name="progressBar" 
                                 Height="4" 
                                 Margin="0,20,0,0"
                                 Visibility="Collapsed"
                                 Style="{StaticResource ModernProgressBar}"
                                 IsIndeterminate="True"/>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>