<Window x:Class="VucemDownloader.SubirArchivosWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Subir Archivos"
        Height="600" Width="700"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F8FAFC"
        ShowInTaskbar="False">
    
    <Grid>
        <Border Background="#FFFFFF" CornerRadius="16" Margin="20">
            <Border.Effect>
                <DropShadowEffect BlurRadius="30" ShadowDepth="8" Opacity="0.1" Direction="270"/>
            </Border.Effect>
            
            <Grid Margin="24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Margin="0,0,0,16">
                    <TextBlock Text="Seleccionar Tipo de Documento"
                               FontSize="20" FontWeight="700" 
                               Foreground="#0F172A"/>
                    <TextBlock Text="Elige el tipo de documento para cada archivo. Cada tipo solo puede usarse una vez."
                               FontSize="12" 
                               Foreground="#64748B" 
                               Margin="0,4,0,0"
                               TextWrapping="Wrap"/>
                </StackPanel>

                <Border Grid.Row="1" Background="#F8FAFC" CornerRadius="8" BorderBrush="#E2E8F0" BorderThickness="1" Padding="12">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="lstArchivos">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#FFFFFF" CornerRadius="8" Padding="14" Margin="0,0,0,10" BorderBrush="#E2E8F0" BorderThickness="1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="220"/>
                                            </Grid.ColumnDefinitions>
                                            
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="{Binding NombreArchivo}" 
                                                           FontSize="13" FontWeight="600" 
                                                           Foreground="#0F172A"
                                                           TextTrimming="CharacterEllipsis"
                                                           ToolTip="{Binding NombreArchivo}"/>
                                                <TextBlock Text="{Binding Tamano}" 
                                                           FontSize="11" 
                                                           Foreground="#64748B"
                                                           Margin="0,2,0,0"/>
                                            </StackPanel>
                                            
                                            <ComboBox Grid.Column="1" 
                                                      x:Name="cmbTipo"
                                                      ItemsSource="{Binding TiposDisponibles}"
                                                      SelectedValue="{Binding TipoSeleccionado}"
                                                      SelectedValuePath="Key"
                                                      DisplayMemberPath="Value"
                                                      VerticalAlignment="Center"
                                                      FontSize="12"
                                                      Padding="8,6"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>

                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                    <Button Content="Cancelar"
                            Click="btnCancelar_Click"
                            Style="{StaticResource SecondaryButton}"
                            Height="44"
                            FontSize="14"
                            Padding="24,0"
                            Margin="0,0,12,0"/>
                    <Button Content="✓ Subir Archivos"
                            Click="btnSubir_Click"
                            Style="{StaticResource PrimaryButton}"
                            Height="44"
                            FontSize="14"
                            Padding="24,0"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>