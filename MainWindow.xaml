<Window x:Class="VucemDownloader.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="VUCEM Suite - Gestor de Expedientes" 
        Height="750" Width="1100" 
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="#F8FAFC">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="64"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#FFFFFF" Padding="24,0" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.05" Direction="270"/>
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="#1E40AF" CornerRadius="8" Width="40" Height="40" Margin="0,0,14,0">
                        <Viewbox Width="20" Height="20" Margin="10">
                            <Path Fill="#FFFFFF" Data="M14,2H6A2,2 0 0,0 4,4V20A2,2 0 0,0 6,22H18A2,2 0 0,0 20,20V8L14,2M18,20H6V4H13V9H18V20Z"/>
                        </Viewbox>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="VUCEM Suite" 
                                   FontSize="18" FontWeight="700" 
                                   Foreground="#0F172A"/>
                        <TextBlock Text="Gestión de Expedientes" 
                                   FontSize="11" 
                                   Foreground="#64748B"/>
                    </StackPanel>
                </StackPanel>
                
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="#F1F5F9" CornerRadius="20" Padding="12,6" Margin="0,0,12,0">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse x:Name="ellipseStatus" Width="8" Height="8" Fill="#EF4444" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock x:Name="lblSesion" 
                                       Text="Sin sesión activa" 
                                       FontSize="12" 
                                       Foreground="#475569" 
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Button Content="⚙" 
                            FontSize="16"
                            Style="{StaticResource IconButton}"
                            Click="btnConfiguracion_Click"
                            ToolTip="Configuración"
                            Padding="10,8"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Expedientes" 
                               FontSize="22" FontWeight="700" 
                               Foreground="#0F172A"/>
                    <Border Background="#DBEAFE" CornerRadius="10" Padding="8,2" Margin="12,0,0,0" VerticalAlignment="Center">
                        <TextBlock x:Name="lblCountExpedientes" Text="0" FontSize="11" FontWeight="600" Foreground="#1E40AF"/>
                    </Border>
                </StackPanel>
                
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="+ Nuevo Expediente" 
                            Style="{StaticResource PrimaryButton}"
                            Click="btnNuevoExpediente_Click"
                            Padding="18,12"
                            FontSize="14"
                            Margin="0,0,10,0"/>
                    <Button Content="Generar ZIP" 
                            Style="{StaticResource AccentButton}"
                            Click="btnGenerarZip_Click"
                            Padding="18,12"
                            FontSize="14"/>
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="340"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource CardBorder}" Margin="0,0,16,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <TextBlock Text="Proyectos" FontSize="14" FontWeight="600" Foreground="#0F172A" Margin="0,0,0,14"/>
                        
                        <Grid Grid.Row="1" Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="txtBusquedaExpediente" 
                                     Style="{StaticResource ModernTextBox}"
                                     KeyDown="txtBusquedaExpediente_KeyDown"/>
                            <Button Grid.Column="1" Content="🔍"
                                    Style="{StaticResource IconButton}"
                                    Click="btnBuscarExpediente_Click"
                                    Padding="10,8"
                                    Margin="8,0,0,0"
                                    ToolTip="Buscar"/>
                        </Grid>

                        <ListBox Grid.Row="2" 
                                 x:Name="lstExpedientes"
                                 Style="{StaticResource ModernListBox}"
                                 ItemContainerStyle="{StaticResource ModernListBoxItem}"
                                 SelectionChanged="lstExpedientes_SelectionChanged">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        
                                        <TextBlock Text="{Binding Nombre}" FontSize="14" FontWeight="600" Foreground="#0F172A"/>
                                        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,4,0,0">
                                            <TextBlock Text="{Binding Rfc}" FontSize="11" Foreground="#64748B"/>
                                            <TextBlock Text=" • " FontSize="11" Foreground="#CBD5E1"/>
                                            <TextBlock Text="{Binding Estado}" FontSize="11" Foreground="#059669"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="1" Grid.RowSpan="2" 
                                                   Text="{Binding FechaCreacion, StringFormat='{}{0:dd/MM/yy}'}" 
                                                   FontSize="10" Foreground="#94A3B8" 
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        
                        <TextBlock x:Name="lblNoExpedientes" 
                                   Text="No hay proyectos aún" 
                                   FontSize="13" 
                                   Foreground="#94A3B8" 
                                   HorizontalAlignment="Center"
                                   Margin="0,40,0,0"
                                   Visibility="Collapsed"/>
                    </Grid>
                </Border>

                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" x:Name="panelInfoExpediente" Style="{StaticResource CardBorder}" Visibility="Collapsed">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock x:Name="lblNombreExpediente" Text="" FontSize="17" FontWeight="600" Foreground="#0F172A"/>
                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                    <TextBlock x:Name="lblRfcExpediente" Text="" FontSize="12" Foreground="#64748B" Margin="0,0,16,0"/>
                                    <TextBlock x:Name="lblAduanaExpediente" Text="" FontSize="12" Foreground="#64748B"/>
                                </StackPanel>
                            </StackPanel>
                            <Button Grid.Column="1" Content="🗑"
                                    Style="{StaticResource DangerButton}"
                                    Click="btnEliminarExpediente_Click"
                                    ToolTip="Eliminar expediente"
                                    Padding="10,6"/>
                        </Grid>
                    </Border>

                    <Border Grid.Row="1" x:Name="panelProgreso" Background="#F8FAFC" CornerRadius="8" Padding="16" Margin="0,12,0,0" Visibility="Collapsed">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Progreso de descarga" FontSize="12" Foreground="#64748B" Margin="0,0,0,8"/>
                                <ProgressBar x:Name="progressExpediente" Style="{StaticResource ModernProgressBar}" Height="6"/>
                            </StackPanel>
                            <TextBlock x:Name="lblProgresoExpediente" Grid.Column="1" Text="0/0" FontSize="14" FontWeight="600" Foreground="#1E40AF" VerticalAlignment="Center" Margin="16,0,0,0"/>
                        </Grid>
                    </Border>

                    <Border Grid.Row="2" Style="{StaticResource CardBorder}" Margin="0,12,0,0" Padding="0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*" MinHeight="200"/>
                            </Grid.RowDefinitions>
                            
                            <Border Background="#F8FAFC" CornerRadius="12,12,0,0" Padding="16,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Documentos" FontSize="14" FontWeight="600" Foreground="#0F172A" VerticalAlignment="Center"/>
                                        <Border Background="#DBEAFE" CornerRadius="8" Padding="6,2" Margin="8,0,0,0" VerticalAlignment="Center">
                                            <TextBlock x:Name="lblCountDocumentos" Text="0" FontSize="11" FontWeight="600" Foreground="#1E40AF"/>
                                        </Border>
                                    </StackPanel>
                                    <Button Grid.Column="1" Content="+ Subir Archivos" 
                                            Style="{StaticResource SuccessButton}"
                                            Click="btnSubirArchivos_Click"
                                            FontSize="12"
                                            Padding="14,8"/>
                                </Grid>
                            </Border>

                            <DataGrid Grid.Row="1" 
                                      x:Name="dgDocumentos" 
                                      Style="{StaticResource ModernDataGrid}"
                                      ColumnHeaderStyle="{StaticResource ModernDataGridColumnHeader}"
                                      CellStyle="{StaticResource ModernDataGridCell}"
                                      RowStyle="{StaticResource ModernDataGridRow}"
                                      CanUserResizeColumns="True"
                                      MinColumnWidth="60">
                                <DataGrid.Columns>
                                    <DataGridCheckBoxColumn Binding="{Binding Seleccionado}" Width="40" CanUserResize="False"/>
                                    <DataGridTextColumn Header="Tipo" Binding="{Binding TipoDocumento}" Width="80" CanUserResize="False"/>
                                    <DataGridTextColumn Header="Descripción" Binding="{Binding Descripcion}" Width="*"/>
                                    <DataGridTemplateColumn Header="Estado" Width="100" CanUserResize="False">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Border CornerRadius="4" Padding="6,3" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding TieneDocumento}" Value="True">
                                                                    <Setter Property="Background" Value="#D1FAE5"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding TieneDocumento}" Value="False">
                                                                    <Setter Property="Background" Value="#FEE2E2"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock FontSize="10" FontWeight="600">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding TieneDocumento}" Value="True">
                                                                        <Setter Property="Text" Value="Subido"/>
                                                                        <Setter Property="Foreground" Value="#059669"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding TieneDocumento}" Value="False">
                                                                        <Setter Property="Text" Value="Faltante"/>
                                                                        <Setter Property="Foreground" Value="#DC2626"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Border>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="Archivo" Binding="{Binding NombreArchivo}" Width="150"/>
                                    <DataGridTemplateColumn Header="Acción" Width="80" CanUserResize="False">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Content="Eliminar"
                                                        FontSize="10"
                                                        Padding="8,4"
                                                        Style="{StaticResource DangerButton}"
                                                        Click="btnEliminarDocumento_Click"
                                                        HorizontalAlignment="Center"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>

                    <Border Grid.Row="3" x:Name="panelDropZone" 
                            Background="#F0FDF4" 
                            BorderBrush="#10B981" 
                            BorderThickness="2" 
                            CornerRadius="10" 
                            Padding="32" 
                            Margin="0,12,0,0"
                            AllowDrop="True"
                            Drop="panelDropZone_Drop"
                            DragOver="panelDropZone_DragOver"
                            DragLeave="panelDropZone_DragLeave"
                            Visibility="Collapsed">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="16" ShadowDepth="0" Opacity="0.15" Color="#10B981"/>
                        </Border.Effect>
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="📁" FontSize="32" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                            <TextBlock Text="Arrastra archivos aquí" FontSize="15" FontWeight="500" Foreground="#0F172A" HorizontalAlignment="Center"/>
                            <TextBlock Text="o haz clic en 'Subir Archivos'" FontSize="12" Foreground="#64748B" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Grid>

        <Border x:Name="progressOverlay" Grid.RowSpan="2" Background="#80000000" Visibility="Collapsed">
            <Border Background="#FFFFFF" CornerRadius="16" Padding="48" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="40" ShadowDepth="8" Opacity="0.2"/>
                </Border.Effect>
                <StackPanel>
                    <ProgressBar x:Name="progressBar" Style="{StaticResource ModernProgressBar}" IsIndeterminate="True" Width="280" Height="6"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                        <Ellipse Width="8" Height="8" Fill="#1E40AF" Margin="0,0,8,0"/>
                        <TextBlock x:Name="lblProgreso" Text="Procesando..." FontSize="14" Foreground="#475569"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</Window>